# ===========================================
# TrendBird - Docker Compose 環境変数
# ===========================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# DATABASE_URL は docker-compose.yml 内で自動設定されるため、
# ここで設定する必要はありません。

# -------------------------------------------
# JWT (required)
# -------------------------------------------
JWT_SECRET=change-me-to-a-random-string

# -------------------------------------------
# X OAuth 2.0 (required)
# -------------------------------------------
# X Developer Portal で取得: https://developer.x.com/
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=http://localhost:3000/callback

# -------------------------------------------
# X API Bearer Token (optional)
# -------------------------------------------
# アプリ専用エンドポイント (tweet counts, search) で使用
# X_BEARER_TOKEN=

# -------------------------------------------
# Anthropic / Claude API (optional)
# -------------------------------------------
# トピック調査で使用。未設定の場合、topic-research ジョブはスキップされます
# ANTHROPIC_API_KEY=sk-ant-xxx

# -------------------------------------------
# Scheduler (optional — デフォルト値で動作します)
# -------------------------------------------
# SCHEDULE_TREND_FETCH=0 */12 * * *
# SCHEDULE_SPIKE_NOTIFICATION=*/5 * * * *
# SCHEDULE_RISING_NOTIFICATION=*/10 * * * *
# SCHEDULE_SCHEDULED_PUBLISH=0 * * * *
# SCHEDULE_REPLY_DM_BATCH=0 * * * *
# SCHEDULE_AUTO_REPLY_BATCH=0 * * * *
# SCHEDULE_TOPIC_RESEARCH=
# SCHEDULER_TIMEZONE=Asia/Tokyo
# SCHEDULER_DISABLED_JOBS=
