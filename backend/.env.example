# ===========================================
# TrendBird Backend - Environment Variables
# ===========================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env

# -------------------------------------------
# Database (required)
# -------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trendbird?sslmode=disable

# -------------------------------------------
# JWT (required)
# -------------------------------------------
JWT_SECRET=your-jwt-secret-here

# -------------------------------------------
# X OAuth 2.0 (required)
# -------------------------------------------
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_REDIRECT_URI=http://localhost:3000/callback

# -------------------------------------------
# Anthropic / Claude API (required)
# -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# -------------------------------------------
# Server (optional)
# -------------------------------------------
# PORT=8080
# ALLOWED_ORIGINS=http://localhost:3000

# -------------------------------------------
# Frontend (optional)
# -------------------------------------------
# FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# JWT Expiry (optional)
# -------------------------------------------
# JWT_EXPIRY=168h

# -------------------------------------------
# Cookie (optional)
# -------------------------------------------
# COOKIE_SECURE=false

# -------------------------------------------
# Scheduler (optional — defaults work out of the box)
# -------------------------------------------
# SCHEDULE_TREND_FETCH=0 */12 * * *
# SCHEDULE_SPIKE_NOTIFICATION=*/5 * * * *
# SCHEDULE_RISING_NOTIFICATION=*/10 * * * *
# SCHEDULE_SCHEDULED_PUBLISH=0 * * * *
# SCHEDULE_REPLY_DM_BATCH=0 * * * *
# SCHEDULE_TOPIC_RESEARCH=
# SCHEDULER_TIMEZONE=Asia/Tokyo
# SCHEDULER_DISABLED_JOBS=
